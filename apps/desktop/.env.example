# ──────────────────────────────────────────────────────
# Musictron Desktop — Environment Variables
# ──────────────────────────────────────────────────────

# URL of the Musictron API server.
# The desktop client fetches MusicKit developer tokens from this server.
# Default: http://localhost:3000 (for local development)
# For production: set to the URL of your deployed Musictron server
VITE_MUSICTRON_SERVER_URL=http://localhost:3000

# Optional: Pre-configure a MusicKit developer token at build time.
# If set, this token is used directly, bypassing the server.
# Only useful for development or if you don't want to run a server.
# VITE_MUSICKIT_DEVELOPER_TOKEN=

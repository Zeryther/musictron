{
  "name": "@musictron/desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Musictron - Apple Music desktop client",
  "author": {
    "name": "Musictron",
    "email": "hello@musictron.app"
  },
  "homepage": "https://github.com/Zeryther/musictron",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "typecheck": "tsc -b --noEmit",
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:vite": "tsc -b && vite build",
    "build:mac": "tsc -b && vite build && electron-builder --mac",
    "build:win": "tsc -b && vite build && electron-builder --win",
    "build:linux": "tsc -b && vite build && electron-builder --linux",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron release node_modules/.vite"
  },
  "dependencies": {
    "@musictron/app": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^36.3.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
